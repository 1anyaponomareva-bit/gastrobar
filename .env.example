# Если сайт по туннелю (ngrok) открывается «пустым» — добавь hostname без https://
# Пример: ALLOWED_DEV_ORIGINS=abc-123.ngrok-free.dev
# Несколько через запятую: host1.ngrok-free.dev,host2.ngrok-free.app
# ALLOWED_DEV_ORIGINS=

# --- Supabase (аналитика спинов) ---
# Project URL из Supabase → Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# anon / publishable key (не service_role!)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Опционально: true — console.log при отправке спина
# NEXT_PUBLIC_SPIN_ANALYTICS_DEBUG=
